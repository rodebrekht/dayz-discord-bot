# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required
DISCORD_TOKEN=your-bot-token-here

# Your Discord server ID (enables instant slash command sync; omit for global sync)
DISCORD_GUILD_ID=

# DayZ server Steam query address (usually same host, port = game port + 1)
DAYZ_QUERY_HOST=127.0.0.1
DAYZ_QUERY_PORT=27016

# Voice channel ID to rename with live player count (optional)
STATUS_CHANNEL_ID=

# Text channel ID for restart warnings (optional)
ALERTS_CHANNEL_ID=

# How often to update presence + voice channel name (seconds, minimum 15)
STATUS_UPDATE_SECONDS=60

# How often to write a population snapshot (seconds, minimum 60)
SNAPSHOT_INTERVAL_SECONDS=300

# Prefix for legacy text commands
COMMAND_PREFIX=!

# Enable/disable command types (true/false)
ENABLE_PREFIX_COMMANDS=true
ENABLE_SLASH_COMMANDS=true

# Restart schedule: minute 0 every 4 hours = 00:00, 04:00, 08:00 ...
RESTART_MINUTE=0
RESTART_EVERY_HOURS=4

# Comma-separated minutes before restart to post warnings
RESTART_WARN_MINUTES=60,30,15,10,5,3,1

# Directory for persistent data (population snapshots)
DATA_DIR=./data
